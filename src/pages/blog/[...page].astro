---
import { getCollection } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export const getStaticPaths = (async ({ paginate }) => {
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	// 注意：getStaticPaths 在隔离上下文执行，pageSize 直接内联（不能引用模块级常量）
	return paginate(posts, { pageSize: 8 });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<'blog'>> };
const { page } = Astro.props;

// 全部文章中出现过的年份（降序、去重），用于左侧筛选栏。
// 注意：分页 props 只携带当前页，所以这里再取一次集合算全量年份。
const allPosts = await getCollection('blog');
const allYears = Array.from(
	new Set(allPosts.map((p) => p.data.pubDate.getFullYear())),
).sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 70%;
				max-width: calc(100% - 2em);
				display: grid;
				grid-template-columns: 7rem 1fr;
				gap: 2.5rem;
				align-items: start;
			}
			.year-filter {
				position: sticky;
				top: 1.5rem;
			}
			.filter-title {
				margin: 0 0 0.6rem;
				font-size: 0.85rem;
				font-weight: 600;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--gray));
			}
			.year-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
			}
			.year-chip {
				width: 100%;
				padding: 0.35rem 0.7rem;
				border: 1px solid rgba(var(--gray-light), 0.9);
				border-radius: 999px;
				background: transparent;
				color: rgb(var(--gray));
				font: inherit;
				font-size: 0.95rem;
				text-align: center;
				cursor: pointer;
				transition: 0.15s ease;
			}
			.year-chip:hover {
				border-color: rgba(var(--gray), 0.6);
			}
			.year-chip.is-active {
				background: rgb(var(--gray-dark));
				border-color: rgb(var(--gray-dark));
				color: #fff;
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list li {
				padding: 1rem 0;
				border-bottom: 1px solid rgba(var(--gray-light), 0.9);
			}
			.post-list li:first-child {
				padding-top: 0;
			}
			.post-list a {
				display: grid;
				grid-template-columns: 4.5fr 4.5fr 1fr;
				align-items: center;
				gap: 0.3rem 1.2rem;
				text-decoration: none;
				transition: 0.2s ease;
			}
			.title {
				grid-column: 1;
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.2rem;
				line-height: 1.35;
				overflow-wrap: break-word;
			}
			.desc {
				grid-column: 2;
				min-width: 0;
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 0.9rem;
				line-height: 1.5;
				overflow-wrap: break-word;
			}
			.date {
				grid-column: 3;
				margin: 0;
				text-align: right;
				color: rgb(var(--gray));
				font-size: 0.85rem;
				white-space: nowrap;
			}
			.post-list a:hover .title {
				color: rgb(var(--accent));
			}
			.pagination {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-top: 2.5rem;
			}
			.pagination .page-info {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.pagination a {
				padding: 0.45rem 1rem;
				border: 1px solid rgba(var(--gray-light), 0.9);
				border-radius: 8px;
				text-decoration: none;
				color: rgb(var(--accent));
				transition: 0.2s ease;
			}
			.pagination a:hover {
				background: rgba(var(--accent-rgb), 0.08);
			}
			.pagination .spacer {
				width: 1px;
			}
			@media (max-width: 720px) {
				main {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.year-filter {
					position: static;
				}
				.year-list {
					flex-direction: row;
					flex-wrap: wrap;
				}
				.year-chip {
					width: auto;
				}
				.post-list a {
					grid-template-columns: 1fr auto;
					gap: 0.2rem 0.8rem;
				}
				.title {
					grid-column: 1 / -1;
				}
				.desc {
					grid-column: 1;
				}
				.date {
					grid-column: 2;
					align-self: start;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<aside class="year-filter" aria-label="按年份筛选">
				<h2 class="filter-title">年份</h2>
				<ul class="year-list">
					{
						allYears.map((y) => (
							<li>
								<button
									type="button"
									class="year-chip is-active"
									data-year={y}
									aria-pressed="true"
								>
									{y}
								</button>
							</li>
						))
					}
				</ul>
			</aside>
			<section class="post-section">
				<ul class="post-list">
					{
						page.data.map((post) => (
							<li data-year={post.data.pubDate.getFullYear()}>
								<a href={`/blog/${post.id}/`}>
									<h2 class="title">{post.data.title}</h2>
									{post.data.description && <p class="desc">{post.data.description}</p>}
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>

				{
					page.lastPage > 1 && (
						<nav class="pagination" aria-label="Pagination">
							{page.url.prev ? (
								<a href={page.url.prev} rel="prev">
									← 上一页
								</a>
							) : (
								<span class="spacer" />
							)}
							<span class="page-info">
								第 {page.currentPage} / {page.lastPage} 页
							</span>
							{page.url.next ? (
								<a href={page.url.next} rel="next">
									下一页 →
								</a>
							) : (
								<span class="spacer" />
							)}
						</nav>
					)
				}
			</section>
		</main>
		<Footer />

		<script>
			// 年份筛选：默认全选；点击切换某年份选中状态，
			// 选中态显示对应年份的文章，未选中则隐藏（仅作用当前页）。
			const chips = document.querySelectorAll<HTMLButtonElement>('.year-chip');
			const items = document.querySelectorAll<HTMLLIElement>('.post-list li');
			function applyFilter() {
				const active = new Set<string>();
				chips.forEach((c) => {
					if (c.classList.contains('is-active') && c.dataset.year) {
						active.add(c.dataset.year);
					}
				});
				items.forEach((li) => {
					const y = li.dataset.year ?? '';
					li.hidden = !active.has(y);
				});
			}
			chips.forEach((chip) => {
				chip.addEventListener('click', () => {
					const on = chip.classList.toggle('is-active');
					chip.setAttribute('aria-pressed', String(on));
					applyFilter();
				});
			});
		</script>
	</body>
</html>
