---
export interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;

// 显示 h1 / h2 / h3 三级标题
const tocHeadings = headings.filter(h => h.depth >= 1 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
	<nav class="toc expanded" aria-label="Table of Contents">
		<button class="toc-tab" aria-label="展开/收起目录">
			<span class="toc-tab-label toc-label-expand">展开目录</span>
			<span class="toc-tab-label toc-label-collapse">收起目录</span>
		</button>
		<div class="toc-content">
			<ul class="toc-list">
				{tocHeadings.map(heading => (
					<li class={`toc-level-${heading.depth}`}>
						<a href={`#${heading.slug}`}>{heading.text}</a>
					</li>
				))}
			</ul>
		</div>
	</nav>
)}

<style>
	.toc {
		position: fixed;
		left: 0;
		top: 0;
		height: 100vh;
		z-index: 100;
		transition: transform 0.3s ease;
	}

	/* 侧边把手：朴素、半透明，hover 时才点亮 */
	.toc-tab {
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(255, 255, 255, 0.82);
		backdrop-filter: blur(8px);
		color: rgb(var(--gray-dark));
		border: 1px solid rgba(var(--gray-light), 0.8);
		border-left: none;
		border-radius: 0 7px 7px 0;
		padding: 1.3rem 0.75rem;
		cursor: pointer;
		box-shadow: 1px 0 6px rgba(var(--black), 0.05);
		transition: color 0.2s ease, background 0.2s ease;
		z-index: 101;
	}

	/* 把手上的竖排文字 */
	.toc-tab-label {
		writing-mode: vertical-rl;
		text-orientation: upright;
		font-size: 1.05rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		line-height: 1;
	}

	/* 收起态显示「展开目录」，展开态显示「收起目录」 */
	.toc-label-collapse {
		display: none;
	}
	.toc.expanded .toc-label-expand {
		display: none;
	}
	.toc.expanded .toc-label-collapse {
		display: inline;
	}

	.toc-tab:hover {
		background: #fff;
		color: rgb(var(--accent-rgb));
	}

	/* 主内容区：垂直居中、限高的半透明悬浮卡片（A 方案） */
	.toc-content {
		position: absolute;
		left: 0;
		top: 50%;
		height: auto;
		max-height: min(82vh, 760px);
		width: 240px;
		background: rgba(252, 252, 253, 0.8);
		backdrop-filter: blur(12px);
		border: 1px solid rgba(var(--gray-light), 0.7);
		border-left: none;
		border-radius: 0 12px 12px 0;
		box-shadow: 4px 0 20px rgba(var(--black), 0.06);
		transform: translate(-250px, -50%);
		transition: transform 0.3s ease;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.toc.expanded .toc-content {
		transform: translate(0, -50%);
	}

	.toc.expanded .toc-tab {
		left: 240px;
	}

	.toc-list {
		list-style: none;
		margin: 0;
		padding: 0.9rem 0.85rem;
		overflow-y: auto;
		flex: 1;
		font-size: 0.9rem;
	}

	.toc-list li {
		margin: 0;
		line-height: 1.3;
	}

	/* h1 标题样式（最顶层，最醒目） */
	.toc-list li.toc-level-1 {
		margin-left: 0;
		margin-top: 0.25rem;
	}

	.toc-list li.toc-level-1 > a {
		font-weight: 700;
		color: rgb(var(--black));
		font-size: 1em;
	}

	/* h2 标题样式（缩进一级） */
	.toc-list li.toc-level-2 {
		margin-left: 0.85rem;
	}

	.toc-list li.toc-level-2 > a {
		font-weight: 500;
		color: rgb(var(--gray-dark));
	}

	/* h3 标题样式（缩进两级） */
	.toc-list li.toc-level-3 {
		margin-left: 1.7rem;
		font-size: 0.88em;
	}

	.toc-list li.toc-level-3 > a {
		color: rgb(var(--gray));
	}

	.toc-list a {
		display: block;
		text-decoration: none;
		padding: 0.2rem 0.5rem;
		border-radius: 6px;
		transition: all 0.2s ease;
		border-left: 3px solid transparent;
	}

	.toc-list a:hover {
		background: rgba(var(--accent-rgb), 0.1);
		color: rgb(var(--accent-rgb));
		border-left-color: rgba(var(--accent-rgb), 0.4);
		transform: translateX(2px);
	}

	.toc-list a.active {
		background: rgba(var(--accent-rgb), 0.15);
		color: rgb(var(--accent-rgb));
		font-weight: 600;
		border-left-color: rgb(var(--accent-rgb));
	}

	/* 屏幕小于 1400px 时隐藏目录 */
	@media (max-width: 1400px) {
		.toc {
			display: none;
		}
	}
</style>

<script>
	// 展开/收起功能
	const tocTab = document.querySelector('.toc-tab');
	const tocNav = document.querySelector('.toc');

	if (tocTab && tocNav) {
		tocTab.addEventListener('click', () => {
			tocNav.classList.toggle('expanded');
		});
	}

	// 高亮当前阅读位置
	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			const id = entry.target.getAttribute('id');
			if (entry.isIntersecting) {
				document.querySelectorAll('.toc-list a').forEach(a => a.classList.remove('active'));
				const activeLink = document.querySelector(`.toc-list a[href="#${id}"]`);
				if (activeLink) activeLink.classList.add('active');
			}
		});
	}, { rootMargin: '-100px 0px -66%' });

	// 观察所有标题
	document.querySelectorAll('.prose h1[id], .prose h2[id], .prose h3[id]').forEach((heading) => {
		observer.observe(heading);
	});
</script>
